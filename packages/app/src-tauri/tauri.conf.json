{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Clara",
	"version": "0.1.0",
	"identifier": "clara",
	"build": {
		"beforeDevCommand": "vite dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "vite build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "Clara",
				"width": 800,
				"height": 600,
				"decorations": false,
				"maximized": true
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self' 'unsafe-inline' plugin: http://plugin.localhost;"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["deb", "appimage", "nsis", "msi", "app"],
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
		"fileAssociations": [
			{
				"ext": ["clara"],
				"name": "Clara project file",
				"description": "A Clara project file.",
				"role": "Editor"
			}
		]
	}
}
