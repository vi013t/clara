{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Wallflower",
	"version": "0.1.0",
	"identifier": "wallflower",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "Wallflower",
				"width": 800,
				"height": 600,
				"decorations": false,
				"maximized": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
		"fileAssociations": [
			{
				"ext": ["wlfr"],
				"name": "Wallflower project file",
				"description": "A Wallflower project file.",
				"role": "Editor"
			}
		],
		"windows": {
			"nsis": {
				"installerHooks": "./windows/hooks.nsi"
			}
		}
	}
}
