{
	"$schema": "https://turbo.build/schema.json",
	"globalPassThroughEnv": ["PATH", "Path", "APPDATA", "LOCALAPPDATA", "USERPROFILE"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "target/**", "build/**", "builds/**", ".svelte-kit/**"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},
		"build:plugins": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		}
	}
}
