{
	"$schema": "https://turbo.build/schema.json",
	"globalPassThroughEnv": ["PATH", "Path", "APPDATA", "LOCALAPPDATA", "USERPROFILE"],
	"tasks": {
		"preprocess": {
			"inputs": ["../../scripts/generate_plugin_bridge.ts"],
			"outputs": ["../../generated/**"]
		},
		"build": {
			"inputs": ["packages/app"],
			"dependsOn": ["^build", "preprocess", "install:plugins"],
			"outputs": ["dist/**", "target/**", "build/**"]
		},
		"dev": {
			"dependsOn": ["^build", "preprocess"],
			"cache": false,
			"persistent": true
		},
		"build:plugins": {
			"dependsOn": ["^build"],
			"inputs": ["packages/plugins/**"],
			"outputs": ["packages/plugins/**/dist/**"]
		},
		"install:plugins": {
			"dependsOn": ["build:plugins"],
			"cache": false,
			"inputs": ["packages/plugins/**/dist/**"],
			"outputs": []
		}
	}
}
